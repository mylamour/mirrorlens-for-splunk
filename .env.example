# Splunk MCP Server connection (required)
SPLUNK_MCP_URL=https://your-splunk-instance/services/mcp
SPLUNK_MCP_TOKEN=your-bearer-token

# SSL verification — set to false for self-signed certs
SPLUNK_VERIFY_SSL=false

# Anthropic Claude API (required)
ANTHROPIC_API_KEY=sk-ant-your-key

# API proxy URL — leave empty for direct Anthropic API
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# Claude model (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-opus-4-6

# ------------------------------------------------------------------
# Optional: only needed if using built-in demo data ingest
# (uv run mirrorlens ingest / uv run mirrorlens demo)
# ------------------------------------------------------------------
# SPLUNK_HEC_URL=https://your-splunk-instance:8088
# SPLUNK_HEC_TOKEN=your-hec-token
# SPLUNK_INDEX=mirrorlens_demo
